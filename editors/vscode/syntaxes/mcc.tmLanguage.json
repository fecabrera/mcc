{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "mcc",
  "scopeName": "source.mcc",
  "patterns": [
    { "include": "#comments" },
    { "include": "#annotations" },
    { "include": "#fstrings" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#numbers" },
    { "include": "#function-definition" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#function-call" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.mcc",
          "match": "//.*$"
        },
        {
          "name": "comment.block.mcc",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "storage.modifier.annotation.mcc",
          "match": "@[A-Za-z_]\\w*"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.mcc",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "include": "#escape" },
        { "include": "#format" }
      ]
    },
    "fstrings": {
      "comment": "Interpolated string literal: f\"... {expr} ...\" with {{/}} literal braces, an optional trailing = inspector, and an optional :modifier format spec. Holes hold full mcc expressions. The region scope is a marker only; the string color is applied piecewise — quotes and literal-text runs carry string.quoted.double — so no hole token ever sits inside a string scope and hole expressions fall back to plain code coloring in every theme. The hole braces use the JS-template punctuation scope, which virtually every theme styles.",
      "name": "string.interpolated.mcc",
      "begin": "\\b(f)(\")",
      "beginCaptures": {
        "1": { "name": "storage.type.string.mcc" },
        "2": { "name": "string.quoted.double.mcc punctuation.definition.string.begin.mcc" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "string.quoted.double.mcc punctuation.definition.string.end.mcc" }
      },
      "patterns": [
        { "include": "#escape" },
        {
          "name": "constant.character.escape.mcc",
          "match": "\\{\\{|\\}\\}"
        },
        {
          "comment": "Literal-text runs between holes — this is what paints the text like a plain string. Ordered after the escape patterns so those win.",
          "name": "string.quoted.double.mcc",
          "match": "[^\"\\\\{}]+"
        },
        {
          "name": "meta.interpolation.mcc",
          "begin": "\\{",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.template-expression.begin.mcc punctuation.section.interpolation.begin.mcc" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.definition.template-expression.end.mcc punctuation.section.interpolation.end.mcc" }
          },
          "contentName": "meta.embedded.line.mcc",
          "patterns": [
            { "include": "#escape" },
            {
              "comment": "The Python-style inspector: a trailing = (before the } or the :modifier) prints the hole's own text as a label.",
              "name": "storage.modifier.inspector.mcc",
              "match": "=(?=\\s*(:[^{}]*)?\\})"
            },
            {
              "comment": "The :modifier format spec, raw text to the closing brace. Requires a non-space right after the colon so a spaced ternary colon is not mistaken for it.",
              "match": "(:)((?=[^\\s{}:])[^{}:]*)(?=\\})",
              "captures": {
                "1": { "name": "punctuation.section.interpolation.mcc" },
                "2": { "name": "constant.other.placeholder.mcc" }
              }
            },
            { "include": "$self" }
          ]
        }
      ]
    },
    "characters": {
      "name": "string.quoted.single.mcc",
      "begin": "'",
      "end": "'",
      "patterns": [
        { "include": "#escape" }
      ]
    },
    "escape": {
      "name": "constant.character.escape.mcc",
      "match": "\\\\[abefnrtv0'\"?\\\\]"
    },
    "format": {
      "name": "constant.other.placeholder.mcc",
      "match": "%[-+ #0]*[0-9]*(?:\\.[0-9]+)?(?:hh|h|ll|l|L|z|j|t)?[diouxXeEfFgGaAcspn%]"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.mcc",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.float.mcc",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b|\\b[0-9]+[eE][+-]?[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.mcc",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "function-definition": {
      "match": "\\b(fn)\\s+([A-Za-z_]\\w*)",
      "captures": {
        "1": { "name": "storage.type.function.mcc" },
        "2": { "name": "entity.name.function.mcc" }
      }
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mcc",
          "match": "\\b(if|else|while|until|for|in|break|continue|unreachable|return|emit|defer|case|when|with|import|extends)\\b"
        },
        {
          "name": "keyword.operator.word.mcc",
          "match": "\\b(and|or|as|sizeof|alignof|offsetof|typename|len)\\b"
        },
        {
          "name": "storage.type.mcc",
          "match": "\\b(fn|let|const|mut|struct|enum|union)\\b"
        },
        {
          "comment": "`type` is contextual: only a keyword as `type <name> = …`.",
          "name": "storage.type.mcc",
          "match": "\\btype\\b(?=\\s+[A-Za-z_]\\w*\\s*=)"
        },
        {
          "comment": "`error` is contextual too: only a keyword as the declaration head `error <name> {`; `error(` stays the result constructor (an ordinary call).",
          "name": "storage.type.mcc",
          "match": "\\berror\\b(?=\\s+[A-Za-z_]\\w*\\s*\\{)"
        }
      ]
    },
    "types": {
      "name": "support.type.primitive.mcc",
      "match": "\\b(int8|int16|int32|int64|uint8|uint16|uint32|uint64|char|byte|bool|float64|void|va_list|any)\\b"
    },
    "constants": {
      "name": "constant.language.mcc",
      "match": "\\b(true|false|null)\\b"
    },
    "function-call": {
      "match": "\\b([A-Za-z_]\\w*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.mcc" }
      }
    },
    "operators": {
      "name": "keyword.operator.mcc",
      "match": "->|\\.\\.\\.|==|!=|<=|>=|<<|>>|[-+*/%!&^|<>=~]"
    }
  }
}
