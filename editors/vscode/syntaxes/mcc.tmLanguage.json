{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "mcc",
  "scopeName": "source.mcc",
  "patterns": [
    { "include": "#comments" },
    { "include": "#annotations" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#numbers" },
    { "include": "#function-definition" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#function-call" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.mcc",
          "match": "//.*$"
        },
        {
          "name": "comment.block.mcc",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "storage.modifier.annotation.mcc",
          "match": "@[A-Za-z_]\\w*"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.mcc",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "include": "#escape" },
        { "include": "#format" }
      ]
    },
    "characters": {
      "name": "string.quoted.single.mcc",
      "begin": "'",
      "end": "'",
      "patterns": [
        { "include": "#escape" }
      ]
    },
    "escape": {
      "name": "constant.character.escape.mcc",
      "match": "\\\\[abefnrtv0'\"?\\\\]"
    },
    "format": {
      "name": "constant.other.placeholder.mcc",
      "match": "%[-+ #0]*[0-9]*(?:\\.[0-9]+)?(?:hh|h|ll|l|L|z|j|t)?[diouxXeEfFgGaAcspn%]"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.mcc",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.float.mcc",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b|\\b[0-9]+[eE][+-]?[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.mcc",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "function-definition": {
      "match": "\\b(fn)\\s+([A-Za-z_]\\w*)",
      "captures": {
        "1": { "name": "storage.type.function.mcc" },
        "2": { "name": "entity.name.function.mcc" }
      }
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mcc",
          "match": "\\b(if|else|while|until|for|in|break|continue|unreachable|return|emit|defer|case|when|with|import|extends)\\b"
        },
        {
          "name": "keyword.operator.word.mcc",
          "match": "\\b(and|or|as|sizeof|alignof|offsetof|typename|len)\\b"
        },
        {
          "name": "storage.type.mcc",
          "match": "\\b(fn|let|const|mut|struct|enum|union)\\b"
        },
        {
          "comment": "`type` is contextual: only a keyword as `type <name> = …`.",
          "name": "storage.type.mcc",
          "match": "\\btype\\b(?=\\s+[A-Za-z_]\\w*\\s*=)"
        }
      ]
    },
    "types": {
      "name": "support.type.primitive.mcc",
      "match": "\\b(int8|int16|int32|int64|uint8|uint16|uint32|uint64|char|byte|bool|float64|void|va_list|any)\\b"
    },
    "constants": {
      "name": "constant.language.mcc",
      "match": "\\b(true|false|null)\\b"
    },
    "function-call": {
      "match": "\\b([A-Za-z_]\\w*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.mcc" }
      }
    },
    "operators": {
      "name": "keyword.operator.mcc",
      "match": "->|\\.\\.\\.|==|!=|<=|>=|<<|>>|[-+*/%!&^|<>=~]"
    }
  }
}
