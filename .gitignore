# Python
__pycache__/
*.py[cod]
.venv/

# Packaging artifacts
/build/
/dist/
*.egg-info/

# Test and coverage artifacts
.pytest_cache/
.coverage
.coverage.*

# macOS
.DS_Store

# Compiler output: intermediate objects and linked executables.
*.o
*.mci
*.a
*.so
*.dylib

# ...but the precompiled standard library is checked in: its interface stubs
# (platform-independent) and the libmc archives (rebuilt per platform by
# build.sh / CI). The libmc/*.o intermediates stay ignored.
!lib/libmc/**/*.mci
!lib/libmc.a
!lib/libmc.so

# mcc writes executables next to the source by default, so anything directly
# in examples/ that is not a source file or the index is a build product. The
# baremetal subdirectory holds sources (its build products land in the repo
# root), so keep it in full.
examples/*
!examples/*.mc
!examples/README.md
!examples/baremetal/
