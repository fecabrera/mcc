# Python
__pycache__/
*.py[cod]
.venv/

# Packaging artifacts
/build/
/dist/
*.egg-info/

# Test and coverage artifacts
.pytest_cache/
.coverage
.coverage.*

# macOS
.DS_Store

# Compiler output: intermediate objects, interface stubs, and libraries. The
# precompiled standard library (lib/libmc.a/.so and the lib/libmc/*.mci stubs)
# is a build product of build.sh -- CI rebuilds it per platform and keeps it as
# a workflow artifact, so none of it is checked in.
*.o
*.mci
*.a
*.so
*.dylib

# mcc writes executables next to the source by default, so anything directly
# in examples/ that is not a source file or the index is a build product. The
# baremetal subdirectory holds sources (its build products land in the repo
# root), so keep it in full.
examples/*
!examples/*.mc
!examples/README.md
!examples/baremetal/
