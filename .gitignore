# Python
__pycache__/
*.py[cod]
.venv/

# Packaging artifacts
/build/
/dist/
*.egg-info/

# Test and coverage artifacts
.pytest_cache/
.coverage
.coverage.*

# macOS
.DS_Store

# Compiler output: intermediate objects, interface stubs, and libraries. The
# precompiled standard library (dist/lib/libmc.a/.so and the dist/lib/**/*.mci
# stubs) is a build product of build.sh -- CI rebuilds it per platform and keeps
# it as a workflow artifact, so none of it is checked in. (dist/ is ignored
# above; these patterns also catch a stray object left beside a source file.)
*.o
*.mci
*.a
*.so
*.dylib

# mcc writes executables next to the source by default, so anything under
# examples/ that is not a source file or an index is a build product. The
# examples are grouped into topical subdirectories, so ignore everything and
# whitelist the sources (.mc), the boot stub (.S), and the index README.md at
# any depth -- the executables dropped next to each source stay ignored.
examples/**
!examples/**/
!examples/**/*.mc
!examples/**/*.S
!examples/**/README.md
